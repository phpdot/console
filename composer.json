{
    "name": "phpdot/console",
    "description": "CLI application framework wrapping symfony/console. DI integration, command discovery, output helpers.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["console", "cli", "command", "symfony", "discovery", "di", "psr-11"],
    "require": {
        "php": ">=8.3",
        "symfony/console": "^7.0",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Console\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Console\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
